---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alberto Maccanico | Developer',
  description = 'Personal CV and portfolio',
} = Astro.props;

const lang = Astro.currentLocale || 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Alberto Maccanico" />

    <meta property="og:title" content={title.toLowerCase()} />
    <meta property="og:description" content={description} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Product Sans Font -->
    <link href="https://fonts.cdnfonts.com/css/product-sans" rel="stylesheet">

    <title>{title}</title>
    
    <style>
      body {
        background-color: transparent !important;
      }
      html {
        background-color: var(--bauhaus-grey) !important;
        background-image: 
          radial-gradient(var(--bauhaus-black) 2px, transparent 2px);
        background-size: 30px 30px;
        background-position: 0 0;
        background-attachment: fixed;
      }
    </style>
  </head>
  <body>
    <!-- Persistent geometric parallax shapes in the fixed 100vh window -->
    <div class="parallax-layer">
      <!-- High speed (foreground) -->
      <div class="geom-shape shape-red" style="top: 10%; right: -5%;" data-speed="0.8"></div>
      
      <!-- Medium speed (midground) -->
      <div class="geom-shape shape-yellow" style="top: 55%; left: -10%; background: var(--bauhaus-blue);" data-speed="0.4"></div>
      <div class="geom-shape shape-blue" style="top: -10%; left: 40%;" data-speed="0.5"></div>
      
      <!-- Low speed (background) -->
      <div class="geom-shape shape-red" style="top: 80%; left: 20%; transform: scale(0.5);" data-speed="0.2"></div>
      <div class="geom-shape shape-yellow" style="top: 85%; right: -15%; opacity: 0.8;" data-speed="0.6"></div>
      <div class="geom-shape shape-blue" style="top: 100%; right: 10%;" data-speed="1.2"></div>
    </div>
    
    <slot />
  </body>
</html>
