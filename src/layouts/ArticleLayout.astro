---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const lang = Astro.currentLocale || 'en';
const blogUrl = lang === 'en' ? '/blog' : `/${lang}/blog`;
---

<Layout title={`${frontmatter.title} | Alberto Maccanico`}>
  
  <div class="content-wrapper min-h-screen flex flex-col bg-white">
    <!-- ARTICLE HEADER -->
    <header class="p-8 sm:p-12 lg:p-16 flex flex-col justify-center bauhaus-border-b" style="background-color: var(--bauhaus-blue); color: var(--bauhaus-white);">
      <a href={blogUrl} class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-white)] font-bold uppercase mb-8 sm:mb-12 w-fit hover:bg-[var(--bauhaus-white)] hover:text-black transition-colors">
        ← return to articles 
      </a>
      <h1 class="text-5xl sm:text-7xl lg:text-[6rem] font-black mb-6 tracking-tighter leading-none">{frontmatter.title}</h1>
      
      {frontmatter.description && (
        <p class="text-2xl sm:text-3xl font-medium max-w-5xl leading-tight border-l-[8px] border-white pl-6">{frontmatter.description}</p>
      )}
      
      <div class="mt-12 flex gap-4">
        {frontmatter.publication && (
          <span class="bg-[var(--bauhaus-black)] text-white px-6 py-3 font-bold border-[3px] border-black text-xl lg:text-2xl uppercase tracking-wider">{frontmatter.publication}</span>
        )}
        {frontmatter.originalUrl && (
          <a href={frontmatter.originalUrl} target="_blank" rel="noopener noreferrer" class="bg-[var(--bauhaus-yellow)] text-black px-6 py-3 font-bold border-[3px] border-black text-xl lg:text-2xl uppercase tracking-wider hover:bg-black hover:text-white transition-colors">
            read original publication ↗
          </a>
        )}
      </div>
    </header>

    <!-- ARTICLE BODY -->
    <article class="p-8 sm:p-12 lg:p-16 flex-1 bg-white markdown-body">
      <div class="prose prose-2xl max-w-[1000px] mx-auto prose-h2:font-black prose-h2:text-5xl prose-h2:uppercase prose-h3:font-black prose-h3:text-4xl prose-p:font-medium prose-p:leading-relaxed prose-a:bg-[var(--bauhaus-yellow)] prose-a:text-black prose-a:px-1 prose-a:font-bold prose-a:no-underline hover:prose-a:bg-black hover:prose-a:text-[var(--bauhaus-white)] prose-img:border-[6px] prose-img:border-black prose-img:rounded-none">
        <slot />
      </div>
    </article>
  </div>
  
</Layout>

<style is:global>
  /* Bauhaus Overrides for standard Markdown */
  .markdown-body .prose p { color: var(--bauhaus-black); margin-bottom: 2rem; font-size: 1.5rem; }
  .markdown-body .prose pre { 
    background: var(--bauhaus-black); 
    color: var(--bauhaus-white); 
    padding: 2.5rem; 
    border: var(--line-weight) solid var(--bauhaus-black); 
    border-radius: 0;
    margin-bottom: 3rem; 
    overflow-x: auto;
  }
  .markdown-body .prose code { 
    font-family: monospace; 
    font-weight: bold; 
    background: var(--bauhaus-grey); 
    padding: 0.2rem 0.5rem; 
    color: var(--bauhaus-black); 
  }
  .markdown-body .prose pre code { background: transparent; color: inherit; padding: 0; }
  .markdown-body .prose blockquote {
    border-left: 12px solid var(--bauhaus-red);
    background: var(--bauhaus-grey);
    padding: 2.5rem;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }
  .markdown-body .prose ul, .markdown-body .prose ol { 
    padding-left: 3rem; 
    margin-bottom: 3rem; 
    font-weight: 600; 
    font-size: 1.5rem; 
    line-height: 1.8; 
    list-style-type: square; 
  }
  .markdown-body .prose li { margin-bottom: 0.75rem; }
</style>
