---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="BUS Roma | Alberto Maccanico">
  <div class="content-wrapper min-h-screen flex flex-col bg-white">

    <header class="p-6 sm:p-12 lg:p-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 bauhaus-border-b" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black);">
      <a href="/demos" class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-black)] font-bold uppercase w-fit hover:bg-[var(--bauhaus-white)] hover:text-[var(--bauhaus-black)] transition-colors">
        ← back to demos
      </a>
      <a href="https://github.com/alcelaser/bus-roma" target="_blank" rel="noopener noreferrer" class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-black)] font-bold uppercase w-fit hover:bg-[var(--bauhaus-white)] hover:text-[var(--bauhaus-black)] transition-colors">
        source code ↗
      </a>
    </header>

    <div class="demo-bauhaus px-4 sm:px-6 lg:px-10 py-10 sm:py-14">

    <!-- Header -->
    <div class="hidden flex items-center justify-between mb-6">
      <a href="/demos" class="text-text-muted hover:text-accent-blue transition-colors flex items-center gap-1.5 font-mono text-xs group">
        <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Projects
      </a>
      <a href="https://github.com/alcelaser/bus-roma" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-text-muted text-xs font-mono hover:text-accent-blue transition-colors">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Source
      </a>
    </div>

    <!-- Title -->
    <div class="text-center mb-8 sm:mb-12 bauhaus-border-b pb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">
        <span class="text-black">BUS</span> <span style="color: var(--bauhaus-red);">Roma</span>
      </h1>
      <p class="text-black text-sm max-w-lg mx-auto">Real-time bus timetables & live arrivals for all ATAC stops in Rome. Built with Flutter & Clean Architecture.</p>
      <div class="mt-3 inline-flex items-center gap-1.5 text-xs font-mono text-black bg-[var(--bauhaus-yellow)] border border-[var(--bauhaus-black)] px-3 py-1 rounded-none">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
        </svg>
        Android app
      </div>
    </div>

    <!-- Two-column layout: phone mockup + content -->
    <div class="flex flex-col lg:flex-row items-start gap-8 lg:gap-14">

      <!-- Phone mockup (simulated screens) -->
      <div class="flex-shrink-0 mx-auto lg:mx-0 w-full sm:w-auto">
        <div class="phone-frame-wrapper relative mx-auto" style="width: 320px;">
          <!-- Phone frame -->
          <div class="rounded-none border-[16px] border-[var(--bauhaus-black)] bg-[var(--bauhaus-white)] overflow-hidden relative">
            <!-- Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-5 bg-[var(--bauhaus-black)] z-20"></div>
            <!-- Simulated screen -->
            <div id="phone-screen" class="rounded-none overflow-hidden bg-[var(--bauhaus-black)] relative" style="height: 580px; border: 5px solid var(--bauhaus-black);">
              <!-- Screen 1: Home -->
              <div class="screen-slide active absolute inset-0 flex flex-col" data-screen="0">
                <!-- Status bar -->
                <div class="bg-[#1a1a1a] px-6 pt-8 pb-3 flex items-center justify-between">
                  <span class="text-white/60 text-[10px] font-mono">9:41</span>
                  <span class="text-white/60 text-[10px]">●●●● ▊ 🔋</span>
                </div>
                <!-- App bar -->
                <div class="bg-[#8B0000] px-5 py-3">
                  <h2 class="text-white font-semibold text-lg">BUS Roma</h2>
                  <div class="mt-2 bg-white/10 rounded-xl px-3 py-2 flex items-center gap-2">
                    <svg class="w-4 h-4 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                    <span class="text-white/40 text-xs">Search stops, lines…</span>
                  </div>
                </div>
                <!-- Content -->
                <div class="flex-1 bg-[#121212] px-4 py-3 overflow-hidden">
                  <p class="text-[#DAA520] text-[10px] font-semibold uppercase tracking-wider mb-2">Favorites</p>
                  <!-- Favorite card -->
                  <div class="bg-[#1e1e1e] rounded-xl p-3 mb-2">
                    <div class="flex items-center justify-between mb-1.5">
                      <span class="text-white text-xs font-medium">Termini (MA)</span>
                      <span class="text-white/40 text-[9px]">75m</span>
                    </div>
                    <div class="flex items-center gap-2 mb-1">
                      <span class="bg-[#0066CC] text-white text-[9px] font-bold px-1.5 py-0.5 rounded">64</span>
                      <span class="text-white/70 text-[10px]">San Pietro</span>
                      <span class="text-green-400 text-[9px] font-mono ml-auto">2 min</span>
                      <span class="bg-green-500/20 text-green-400 text-[8px] px-1 rounded font-mono">LIVE</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class="bg-[#CC3300] text-white text-[9px] font-bold px-1.5 py-0.5 rounded">H</span>
                      <span class="text-white/70 text-[10px]">Cornelia</span>
                      <span class="text-orange-400 text-[9px] font-mono ml-auto">7 min</span>
                      <span class="bg-orange-500/20 text-orange-400 text-[8px] px-1 rounded font-mono">+3m</span>
                    </div>
                  </div>
                  <div class="bg-[#1e1e1e] rounded-xl p-3 mb-3">
                    <div class="flex items-center justify-between mb-1.5">
                      <span class="text-white text-xs font-medium">Colosseo</span>
                      <span class="text-white/40 text-[9px]">310m</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class="bg-[#006633] text-white text-[9px] font-bold px-1.5 py-0.5 rounded">75</span>
                      <span class="text-white/70 text-[10px]">Poerio/Piramide</span>
                      <span class="text-green-400 text-[9px] font-mono ml-auto">4 min</span>
                      <span class="bg-green-500/20 text-green-400 text-[8px] px-1 rounded font-mono">LIVE</span>
                    </div>
                  </div>
                  <p class="text-[#DAA520] text-[10px] font-semibold uppercase tracking-wider mb-2">Nearby stops</p>
                  <div class="bg-[#1e1e1e] rounded-xl p-3 mb-2">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-full bg-[#8B0000]/30 flex items-center justify-center">
                        <svg class="w-3 h-3 text-[#FF6B5A]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                      </div>
                      <div>
                        <p class="text-white text-[10px] font-medium">Cavour</p>
                        <p class="text-white/40 text-[9px]">120m away · 3 lines</p>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Bottom nav -->
                <div class="bg-[#1a1a1a] border-t border-white/5 px-2 py-1.5 flex justify-around">
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 rounded-full bg-[#DAA520]/20 flex items-center justify-center"><svg class="w-3 h-3 text-[#DAA520]" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg></div>
                    <span class="text-[#DAA520] text-[7px]">Home</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg></div>
                    <span class="text-white/40 text-[7px]">Lines</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg></div>
                    <span class="text-white/40 text-[7px]">Navigate</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg></div>
                    <span class="text-white/40 text-[7px]">Map</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg></div>
                    <span class="text-white/40 text-[7px]">Alerts</span>
                  </div>
                </div>
              </div>

              <!-- Screen 2: Stop Detail -->
              <div class="screen-slide absolute inset-0 flex flex-col" data-screen="1" style="opacity:0; transform: translateX(100%);">
                <div class="bg-[#1a1a1a] px-6 pt-8 pb-3 flex items-center justify-between">
                  <span class="text-white/60 text-[10px] font-mono">9:41</span>
                  <span class="text-white/60 text-[10px]">●●●● ▊ 🔋</span>
                </div>
                <div class="bg-[#8B0000] px-5 py-3 flex items-center gap-3">
                  <svg class="w-4 h-4 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
                  <div>
                    <h2 class="text-white font-semibold text-sm">Termini (MA)</h2>
                    <p class="text-white/60 text-[10px]">Stop 70101</p>
                  </div>
                  <svg class="w-4 h-4 text-[#DAA520] ml-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div class="flex-1 bg-[#121212] px-4 py-3 overflow-hidden">
                  <p class="text-white/50 text-[9px] font-mono mb-3">Live departures — auto-refresh 30s</p>
                  <!-- Departure rows -->
                  <div class="space-y-2">
                    <div class="bg-[#1e1e1e] rounded-lg p-2.5 flex items-center gap-2.5">
                      <span class="bg-[#0066CC] text-white text-[9px] font-bold px-2 py-1 rounded min-w-[28px] text-center">64</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-white text-[10px] truncate">San Pietro</p>
                        <p class="text-white/40 text-[8px]">14:23 → <span class="text-green-400">14:25</span></p>
                      </div>
                      <div class="text-right">
                        <p class="text-green-400 text-xs font-mono font-bold">2'</p>
                        <span class="bg-green-500/20 text-green-400 text-[7px] px-1 rounded font-mono">LIVE</span>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-lg p-2.5 flex items-center gap-2.5">
                      <span class="bg-[#CC3300] text-white text-[9px] font-bold px-2 py-1 rounded min-w-[28px] text-center">H</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-white text-[10px] truncate">Cornelia</p>
                        <p class="text-white/40 text-[8px]">14:27 → <span class="text-orange-400">14:30</span></p>
                      </div>
                      <div class="text-right">
                        <p class="text-orange-400 text-xs font-mono font-bold">7'</p>
                        <span class="bg-orange-500/20 text-orange-400 text-[7px] px-1 rounded font-mono">+3m</span>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-lg p-2.5 flex items-center gap-2.5">
                      <span class="bg-[#339933] text-white text-[9px] font-bold px-2 py-1 rounded min-w-[28px] text-center">170</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-white text-[10px] truncate">Agricoltura</p>
                        <p class="text-white/40 text-[8px]">14:35</p>
                      </div>
                      <div class="text-right">
                        <p class="text-white/70 text-xs font-mono font-bold">12'</p>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-lg p-2.5 flex items-center gap-2.5">
                      <span class="bg-[#0066CC] text-white text-[9px] font-bold px-2 py-1 rounded min-w-[28px] text-center">64</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-white text-[10px] truncate">San Pietro</p>
                        <p class="text-white/40 text-[8px]">14:43 → <span class="text-green-400">14:42</span></p>
                      </div>
                      <div class="text-right">
                        <p class="text-green-400 text-xs font-mono font-bold">19'</p>
                        <span class="bg-green-500/20 text-green-400 text-[7px] px-1 rounded font-mono">-1m</span>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-lg p-2.5 flex items-center gap-2.5">
                      <span class="bg-[#CC6600] text-white text-[9px] font-bold px-2 py-1 rounded min-w-[28px] text-center">40</span>
                      <div class="flex-1 min-w-0">
                        <p class="text-white text-[10px] truncate">Borghese</p>
                        <p class="text-white/40 text-[8px]">14:50</p>
                      </div>
                      <div class="text-right">
                        <p class="text-white/70 text-xs font-mono font-bold">27'</p>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Bottom nav (same) -->
                <div class="bg-[#1a1a1a] border-t border-white/5 px-2 py-1.5 flex justify-around">
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 rounded-full bg-[#DAA520]/20 flex items-center justify-center"><svg class="w-3 h-3 text-[#DAA520]" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg></div>
                    <span class="text-[#DAA520] text-[7px]">Home</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg></div>
                    <span class="text-white/40 text-[7px]">Lines</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg></div>
                    <span class="text-white/40 text-[7px]">Navigate</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg></div>
                    <span class="text-white/40 text-[7px]">Map</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg></div>
                    <span class="text-white/40 text-[7px]">Alerts</span>
                  </div>
                </div>
              </div>

              <!-- Screen 3: Map -->
              <div class="screen-slide absolute inset-0 flex flex-col" data-screen="2" style="opacity:0; transform: translateX(100%);">
                <div class="bg-[#1a1a1a] px-6 pt-8 pb-3 flex items-center justify-between">
                  <span class="text-white/60 text-[10px] font-mono">9:41</span>
                  <span class="text-white/60 text-[10px]">●●●● ▊ 🔋</span>
                </div>
                <div class="bg-[#8B0000] px-5 py-3">
                  <h2 class="text-white font-semibold text-sm">Map</h2>
                </div>
                <!-- Simulated map -->
                <div class="flex-1 relative overflow-hidden" style="background: #2a3a2a;">
                  <!-- Map grid -->
                  <div class="absolute inset-0" style="background: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 30px 30px;"></div>
                  <!-- Roads -->
                  <div class="absolute" style="left: 20%; top: 0; bottom: 0; width: 2px; background: rgba(255,255,255,0.08);"></div>
                  <div class="absolute" style="left: 55%; top: 0; bottom: 0; width: 3px; background: rgba(255,255,255,0.1);"></div>
                  <div class="absolute" style="top: 35%; left: 0; right: 0; height: 2px; background: rgba(255,255,255,0.08);"></div>
                  <div class="absolute" style="top: 65%; left: 0; right: 0; height: 3px; background: rgba(255,255,255,0.1);"></div>
                  <!-- Stop markers -->
                  <div class="absolute" style="left: 45%; top: 40%;">
