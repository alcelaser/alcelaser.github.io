<script>
  // Responsive phone scaling for small viewports
  function scalePhone() {
    const wrapper = document.querySelector('.phone-frame-wrapper') as HTMLElement;
    if (!wrapper) return;
    const available = wrapper.parentElement!.clientWidth;
    const phoneW = 320;
    if (available < phoneW) {
      const s = available / phoneW;
      wrapper.style.transform = `scale(${s})`;
      wrapper.style.transformOrigin = 'top center';
      wrapper.style.marginBottom = `-${(1 - s) * wrapper.offsetHeight}px`;
    } else {
      wrapper.style.transform = '';
      wrapper.style.marginBottom = '';
    }
  }
  scalePhone();
  window.addEventListener('resize', scalePhone);

  // Screen slideshow for phone mockup
  const slides = document.querySelectorAll('.screen-slide');
  const dots = document.querySelectorAll('.screen-dot');
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides.forEach((s, i) => {
      const el = s as HTMLElement;
      if (i === idx) {
        el.style.opacity = '1';
        el.style.transform = 'translateX(0)';
        el.classList.add('active');
      } else if (i < idx) {
        el.style.opacity = '0';
        el.style.transform = 'translateX(-100%)';
        el.classList.remove('active');
      } else {
        el.style.opacity = '0';
        el.style.transform = 'translateX(100%)';
        el.classList.remove('active');
      }
      el.style.transition = 'all 0.4s ease';
    });
    dots.forEach((d, i) => {
      const dot = d as HTMLElement;
      dot.className = 'screen-dot w-2 h-2 rounded-full transition-colors cursor-pointer';
      dot.style.background = i === idx ? 'var(--bauhaus-red)' : 'rgba(255,255,255,0.2)';
    });
    current = idx;
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  dots.forEach(d => {
    d.addEventListener('click', () => {
      const target = parseInt((d as HTMLElement).dataset.target || '0');
      goTo(target);
      clearInterval(interval);
      interval = setInterval(next, 5000);
    });
  });

  interval = setInterval(next, 5000);
</script>
