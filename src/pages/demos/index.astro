---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { useTranslations } from '../../i18n/utils';

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang);

const demos = [
  {
    title: 'Albert Dashboard',
    description: 'Real-time investment dashboard tracking stocks, crypto, and commodities with interactive TradingView charts.',
    tech: ['React 19', 'TailwindCSS 4', 'TradingView Charts'],
    href: '/demos/albert-dashboard/',
    external: true,
    gradient: 'from-blue-500/20 to-cyan-500/20',
    hoverGradient: 'group-hover:from-blue-500/30 group-hover:to-cyan-500/30',
    iconColor: 'text-blue-400',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
    </svg>`,
    badge: 'Live Data',
    badgeColor: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
    repo: 'https://github.com/alcelaser/albert-dashboard',
  },
  {
    title: 'Codice Fiscale Generator',
    description: 'Calculate an Italian tax identification code (Codice Fiscale) using the official algorithm, ported from Python to the web.',
    tech: ['TypeScript', 'Astro', '8 270 municipalities'],
    href: '/demos/cfpython',
    external: false,
    gradient: 'from-green-500/20 to-emerald-500/20',
    hoverGradient: 'group-hover:from-green-500/30 group-hover:to-emerald-500/30',
    iconColor: 'text-green-400',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
    </svg>`,
    badge: 'Interactive',
    badgeColor: 'text-green-400 bg-green-500/10 border-green-500/20',
    repo: 'https://github.com/alcelaser/cfpython',
  },
  {
    title: 'Limited Lands',
    description: 'MTG companion app: mana calculator, life counter (2–10 players), deck builder, Swiss tournaments, and 17Lands card ratings.',
    tech: ['Flutter', 'Riverpod', 'Material 3', '303 tests'],
    href: '/demos/limitedlands',
    external: false,
    gradient: 'from-amber-500/20 to-yellow-500/20',
    hoverGradient: 'group-hover:from-amber-500/30 group-hover:to-yellow-500/30',
    iconColor: 'text-amber-400',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
    </svg>`,
    badge: 'Showcase',
    badgeColor: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
    repo: 'https://github.com/alcelaser/LimitedLands',
  },
  {
    title: 'BUS Roma',
    description: 'Real-time bus timetables and live arrivals for all ATAC stops in Rome. Clean Architecture with Drift SQLite and GTFS-RT feeds.',
    tech: ['Flutter', 'Drift SQLite', 'GTFS-RT', '352 tests'],
    href: '/demos/bus-roma',
    external: false,
    gradient: 'from-red-500/20 to-rose-500/20',
    hoverGradient: 'group-hover:from-red-500/30 group-hover:to-rose-500/30',
    iconColor: 'text-red-400',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
    </svg>`,
    badge: 'Showcase',
    badgeColor: 'text-red-400 bg-red-500/10 border-red-500/20',
    repo: 'https://github.com/alcelaser/bus-roma',
  },
];
---

<Layout title={`${t('demos.title')} | Alberto Maccanico`}>
  <Nav />

  <div id="demos-content" class="max-w-5xl mx-auto py-24 sm:py-32 px-4 sm:px-6 min-h-screen relative z-10">
    <div class="mb-10 sm:mb-16 section-fade">
      <div class="mb-8">
        <a href={lang === 'en' ? '/' : `/${lang}`} class="text-text-muted hover:text-accent-blue transition-colors flex items-center gap-2 font-mono text-sm w-fit">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          {t('demos.back')}
        </a>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{t('demos.title')}</span>
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed max-w-2xl">{t('demos.subtitle')}</p>
      <div class="w-16 h-1 bg-gradient-to-r from-accent-blue to-accent-purple rounded-full mt-8"></div>
    </div>

    <div class="grid gap-5 sm:gap-8">
      {demos.map(demo => (
        <a
          href={demo.href}
          target={demo.external ? '_blank' : undefined}
          rel={demo.external ? 'noopener noreferrer' : undefined}
          class="glass rounded-2xl p-5 sm:p-8 section-fade glow-border group block hover:scale-[1.01] transition-transform cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4 sm:mb-6">
            <div class={`w-11 h-11 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl bg-gradient-to-br ${demo.gradient} ${demo.hoverGradient} flex items-center justify-center transition-colors`}>
              <Fragment set:html={demo.icon} />
            </div>
            <div class="flex items-center gap-2">
              <span class={`text-xs font-mono ${demo.badgeColor} border px-2.5 py-0.5 rounded-full`}>{demo.badge}</span>
              {demo.external ? (
                <svg class="w-4 h-4 text-text-muted group-hover:text-accent-blue transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              ) : (
                <svg class="w-4 h-4 text-text-muted group-hover:text-accent-blue transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              )}
            </div>
          </div>

          <h2 class="font-semibold text-text-primary text-lg sm:text-xl md:text-2xl mb-2 sm:mb-3 group-hover:text-accent-blue transition-colors">{demo.title}</h2>
          <p class="text-text-secondary text-xs sm:text-sm leading-relaxed mb-4 sm:mb-5">{demo.description}</p>

          <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-3 sm:mb-4">
            {demo.tech.map(t => (
              <span class="text-xs font-mono text-text-muted bg-bg-primary/40 border border-border-glass px-2.5 py-1 rounded-lg">{t}</span>
            ))}
          </div>

          <p class="text-text-muted text-xs font-mono hover:text-accent-blue transition-colors">
            <span class="inline-flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              {demo.repo.replace('https://github.com/', '')}
            </span>
          </p>
        </a>
      ))}
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const container = document.getElementById('demos-content');
  if (container) {
    const faders = container.querySelectorAll('.section-fade');
    gsap.fromTo(faders,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: 'power3.out',
        scrollTrigger: { trigger: container, start: 'top 80%' },
      }
    );
  }
</script>
