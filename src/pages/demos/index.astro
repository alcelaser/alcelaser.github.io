---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang);

const demos = [
  {
    title: 'Albert Dashboard',
    description: 'Real-time investment dashboard tracking stocks, crypto, and commodities with interactive TradingView charts.',
    tech: ['React 19', 'TailwindCSS 4'],
    href: '/demos/albert-dashboard/',
    external: true,
  },
  {
    title: 'Codice Fiscale Generator',
    description: 'Calculate an Italian tax identification code (Codice Fiscale) using the official algorithm, ported from Python to the web.',
    tech: ['TypeScript', 'Astro'],
    href: '/demos/cfpython',
    external: false,
  },
  {
    title: 'Limited Lands',
    description: 'MTG companion app: mana calculator, life counter (2–10 players), deck builder, Swiss tournaments, and 17Lands card ratings.',
    tech: ['Flutter', 'Riverpod'],
    href: '/demos/limitedlands',
    external: false,
  },
  {
    title: 'BUS Roma',
    description: 'Real-time bus timetables and live arrivals for all ATAC stops in Rome. Clean Architecture with Drift SQLite and GTFS-RT feeds.',
    tech: ['Flutter', 'Drift SQLite'],
    href: '/demos/bus-roma',
    external: false,
  },
];
---

<Layout title={`${t('demos.title')} | Alberto Maccanico`}>
  
  <div class="content-wrapper min-h-screen flex flex-col bg-white">
    <!-- DEMOS HEADER -->
    <header class="p-6 sm:p-12 lg:p-16 flex flex-col justify-center bauhaus-border-b" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black);">
      <a href={lang === 'en' ? '/' : `/${lang}`} class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-black)] font-bold uppercase mb-8 sm:mb-12 w-fit hover:bg-[var(--bauhaus-black)] hover:text-white transition-colors">
        ← {t('demos.back')}
      </a>
      <h1 class="text-5xl sm:text-7xl lg:text-[8rem] font-black tracking-tighter leading-none mb-6">{t('demos.title')}</h1>
      <p class="text-xl sm:text-3xl lg:text-4xl font-medium max-w-4xl border-l-[8px] border-black pl-6 leading-tight">{t('demos.subtitle')}</p>
    </header>

    <!-- DEMOS LIST (Ruler strip paradigm) -->
    <div class="flex-1 flex flex-col">
      {demos.map((demo, i) => {
        const bgs = ['var(--bauhaus-blue)', 'var(--bauhaus-white)', 'var(--bauhaus-red)', 'var(--bauhaus-grey)'];
        const txs = ['var(--bauhaus-white)', 'var(--bauhaus-black)', 'var(--bauhaus-white)', 'var(--bauhaus-black)'];
        
        const bg = bgs[i % bgs.length];
        const tx = txs[i % txs.length];
        
        return (
          <a
            href={demo.href}
            target={demo.external ? '_blank' : undefined}
            rel={demo.external ? 'noopener noreferrer' : undefined}
            class="block p-6 sm:p-12 lg:p-16 bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row justify-between xl:items-center gap-8 lg:gap-16 hover:opacity-90 transition-opacity" 
            style={`background-color: ${bg}; color: ${tx};`}
          >
            <div class="xl:w-2/3">
              <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-4 sm:mb-6 tracking-tight leading-none">{demo.title}</h2>
              <p class="text-xl sm:text-2xl lg:text-3xl font-medium max-w-4xl leading-tight mb-8">{demo.description}</p>
              
              <div class="flex flex-wrap gap-4">
                {demo.tech.map(t => (
                  <span class="inline-block px-4 py-2 text-base sm:text-xl font-bold uppercase border-[3px]" style={`border-color: ${tx};`}>
                    {t}
                  </span>
                ))}
              </div>
            </div>
            
            <div class="xl:w-1/3 xl:text-right pt-4 xl:pt-0">
               <span class="inline-block px-6 py-4 bg-black text-white text-2xl sm:text-3xl font-black uppercase transition-transform hover:-translate-y-1 w-fit">
                 {demo.external ? 'launch external ↗' : 'launch demo →'}
               </span>
            </div>
          </a>
        );
      })}
    </div>

  </div>

</Layout>
