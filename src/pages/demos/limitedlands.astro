<script>
  const slides = document.querySelectorAll('.screen-slide') as NodeListOf<HTMLElement>;
  const dots = document.querySelectorAll('.screen-dot') as NodeListOf<HTMLElement>;
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides.forEach((s, i) => {
      if (i === index) {
        s.style.opacity = '1';
        s.style.transform = 'translateX(0)';
        s.classList.add('active');
      } else if (i < index) {
        s.style.opacity = '0';
        s.style.transform = 'translateX(-100%)';
        s.classList.remove('active');
      } else {
        s.style.opacity = '0';
        s.style.transform = 'translateX(100%)';
        s.classList.remove('active');
      }
    });
    dots.forEach((d, i) => {
      d.className = `screen-dot w-2 h-2 rounded-full transition-all ${i === index ? 'bg-amber-400' : 'bg-white/20'}`;
    });
    current = index;
  }

  function startAutoPlay() {
    interval = setInterval(() => {
      goTo((current + 1) % slides.length);
    }, 5000);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(interval);
      goTo(Number(dot.dataset.target));
      startAutoPlay();
    });
  });

  // Add CSS transitions
  slides.forEach(s => {
    s.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
  });

  startAutoPlay();
</script>
