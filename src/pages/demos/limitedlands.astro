---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
---

<Layout title="Limited Lands | Alberto Maccanico">
  <Nav />

  <div class="max-w-6xl mx-auto px-6 relative z-10 min-h-screen py-28">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <a href="/demos" class="text-text-muted hover:text-accent-blue transition-colors flex items-center gap-1.5 font-mono text-xs group">
        <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Projects
      </a>
      <a href="https://github.com/alcelaser/LimitedLands" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-text-muted text-xs font-mono hover:text-accent-blue transition-colors">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Source
      </a>
    </div>

    <!-- Title -->
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">
        <span class="gradient-text">Limited Lands</span>
      </h1>
      <p class="text-text-muted text-sm max-w-lg mx-auto">MTG companion app — mana calculator, life counter, deck builder, Swiss tournaments & 17Lands ratings.</p>
      <div class="mt-3 inline-flex items-center gap-1.5 text-xs font-mono text-amber-400 bg-amber-500/10 border border-amber-500/20 px-3 py-1 rounded-full">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
        </svg>
        Android app — Flutter Web incompatible with outdated SDK
      </div>
    </div>

    <!-- Two-column layout: phone mockup + content -->
    <div class="flex flex-col lg:flex-row items-start gap-10 lg:gap-14">

      <!-- Phone mockup (simulated screens) -->
      <div class="flex-shrink-0 mx-auto lg:mx-0">
        <div class="relative" style="width: 320px;">
          <!-- Phone frame -->
          <div class="rounded-[3rem] border-[14px] border-gray-800 bg-gray-800 shadow-2xl shadow-black/50 overflow-hidden relative">
            <!-- Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-gray-800 rounded-b-2xl z-20"></div>
            <!-- Simulated screen -->
            <div id="phone-screen" class="rounded-[2.2rem] overflow-hidden bg-black relative" style="height: 580px;">

              <!-- Screen 1: Mana Calculator -->
              <div class="screen-slide active absolute inset-0 flex flex-col" data-screen="0">
                <div class="bg-[#1a1a1a] px-6 pt-8 pb-3 flex items-center justify-between">
                  <span class="text-white/60 text-[10px] font-mono">9:41</span>
                  <span class="text-white/60 text-[10px]">●●●● ▊ 🔋</span>
                </div>
                <!-- App bar -->
                <div class="bg-[#1B5E20] px-5 py-3">
                  <h2 class="text-white font-semibold text-lg">Mana Calculator</h2>
                  <p class="text-white/60 text-[10px]">Limited · 17 lands</p>
                </div>
                <!-- Content -->
                <div class="flex-1 bg-[#121212] px-4 py-3 overflow-hidden">
                  <p class="text-amber-400 text-[10px] font-semibold uppercase tracking-wider mb-3">Mana Sources</p>
                  <!-- Mana color rows -->
                  <div class="space-y-2 mb-4">
                    <div class="bg-[#1e1e1e] rounded-xl p-3 flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center text-sm font-bold text-gray-800">W</div>
                        <div>
                          <p class="text-white text-[11px] font-medium">White</p>
                          <p class="text-white/40 text-[9px]">12 pips · 28%</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">−</div>
                        <span class="text-white font-mono text-sm font-bold w-5 text-center">5</span>
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">+</div>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-xl p-3 flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-[#0E68AB] flex items-center justify-center text-sm font-bold text-white">U</div>
                        <div>
                          <p class="text-white text-[11px] font-medium">Blue</p>
                          <p class="text-white/40 text-[9px]">8 pips · 19%</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">−</div>
                        <span class="text-white font-mono text-sm font-bold w-5 text-center">3</span>
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">+</div>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-xl p-3 flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-[#150B00] flex items-center justify-center text-sm font-bold text-white">B</div>
                        <div>
                          <p class="text-white text-[11px] font-medium">Black</p>
                          <p class="text-white/40 text-[9px]">6 pips · 14%</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">−</div>
                        <span class="text-white font-mono text-sm font-bold w-5 text-center">2</span>
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">+</div>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-xl p-3 flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-[#D32029] flex items-center justify-center text-sm font-bold text-white">R</div>
                        <div>
                          <p class="text-white text-[11px] font-medium">Red</p>
                          <p class="text-white/40 text-[9px]">10 pips · 23%</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">−</div>
                        <span class="text-white font-mono text-sm font-bold w-5 text-center">4</span>
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">+</div>
                      </div>
                    </div>
                    <div class="bg-[#1e1e1e] rounded-xl p-3 flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-[#00733E] flex items-center justify-center text-sm font-bold text-white">G</div>
                        <div>
                          <p class="text-white text-[11px] font-medium">Green</p>
                          <p class="text-white/40 text-[9px]">7 pips · 16%</p>
                        </div>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">−</div>
                        <span class="text-white font-mono text-sm font-bold w-5 text-center">3</span>
                        <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-white text-[10px]">+</div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Bottom nav -->
                <div class="bg-[#1a1a1a] border-t border-white/5 px-2 py-1.5 flex justify-around">
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 rounded-full bg-amber-500/20 flex items-center justify-center"><svg class="w-3 h-3 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6z"/></svg></div>
                    <span class="text-amber-400 text-[7px]">Mana</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg></div>
                    <span class="text-white/40 text-[7px]">Life</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-1.007.662-1.862 1.574-2.147"/></svg></div>
                    <span class="text-white/40 text-[7px]">Deck</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172"/></svg></div>
                    <span class="text-white/40 text-[7px]">Tourney</span>
                  </div>
                  <div class="flex flex-col items-center gap-0.5">
                    <div class="w-5 h-5 flex items-center justify-center"><svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg></div>
                    <span class="text-white/40 text-[7px]">17Lands</span>
                  </div>
                </div>
              </div>

              <!-- Screen 2: Life Counter -->
              <div class="screen-slide absolute inset-0 flex flex-col" data-screen="1" style="opacity:0; transform: translateX(100%);">
                <div class="bg-[#1a1a1a] px-6 pt-8 pb-3 flex items-center justify-between">
                  <span class="text-white/60 text-[10px] font-mono">9:41</span>
                  <span class="text-white/60 text-[10px]">●●●● ▊ 🔋</span>
                </div>
                <div class="bg-[#B71C1C] px-5 py-3 flex items-center justify-between">
                  <div>
                    <h2 class="text-white font-semibold text-sm">Life Counter</h2>
                    <p class="text-white/60 text-[10px]">4 Players · Commander</p>
                  </div>
                  <div class="flex gap-2">
                    <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center">
                      <svg class="w-3.5 h-3.5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
                    </div>
                    <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center">
                      <svg class="w-3.5 h-3.5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                  </div>
                </div>
                <div class="flex-1 bg-[#121212] overflow-hidden">
                  <!-- 2x2 player grid -->
                  <div class="grid grid-cols-2 h-full">
                    <div class="border-r border-b border-white/5 flex flex-col items-center justify-center bg-gradient-to-br from-[#1B5E20]/20 to-transparent relative">
                      <p class="text-white/50 text-[9px] font-mono absolute top-2 left-3">Player 1</p>
                      <span class="text-white text-4xl font-bold font-mono">40</span>
                      <div class="flex gap-3 mt-2">
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">−</div>
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">+</div>
                      </div>
                      <div class="flex gap-2 mt-2">
                        <span class="text-[8px] text-purple-400 bg-purple-500/10 px-1.5 py-0.5 rounded">☠ 0</span>
                        <span class="text-[8px] text-green-400 bg-green-500/10 px-1.5 py-0.5 rounded">⚗ 0</span>
                      </div>
                    </div>
                    <div class="border-b border-white/5 flex flex-col items-center justify-center bg-gradient-to-br from-[#0E68AB]/20 to-transparent relative">
                      <p class="text-white/50 text-[9px] font-mono absolute top-2 left-3">Player 2</p>
                      <span class="text-white text-4xl font-bold font-mono">37</span>
                      <div class="flex gap-3 mt-2">
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">−</div>
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">+</div>
                      </div>
                      <div class="flex gap-2 mt-2">
                        <span class="text-[8px] text-purple-400 bg-purple-500/10 px-1.5 py-0.5 rounded">☠ 0</span>
                        <span class="text-[8px] text-green-400 bg-green-500/10 px-1.5 py-0.5 rounded">⚗ 0</span>
                      </div>
                    </div>
                    <div class="border-r border-white/5 flex flex-col items-center justify-center bg-gradient-to-br from-[#D32029]/20 to-transparent relative">
                      <p class="text-white/50 text-[9px] font-mono absolute top-2 left-3">Player 3</p>
                      <span class="text-white text-4xl font-bold font-mono">40</span>
                      <div class="flex gap-3 mt-2">
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">−</div>
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">+</div>
                      </div>
                      <div class="flex gap-2 mt-2">
                        <span class="text-[8px] text-purple-400 bg-purple-500/10 px-1.5 py-0.5 rounded">☠ 0</span>
                        <span class="text-[8px] text-green-400 bg-green-500/10 px-1.5 py-0.5 rounded">⚗ 0</span>
                      </div>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-gradient-to-br from-[#150B00]/40 to-transparent relative">
                      <p class="text-white/50 text-[9px] font-mono absolute top-2 left-3">Player 4</p>
                      <span class="text-red-400 text-4xl font-bold font-mono">18</span>
                      <div class="flex gap-3 mt-2">
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">−</div>
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/60 text-sm font-bold">+</div>
                      </div>
                      <div class="flex gap-2 mt-2">
                        <span class="text-[8px] text-purple-400 bg-purple-500/10 px-1.5 py-0.5 rounded">☠ 3</span>
