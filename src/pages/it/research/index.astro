---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import { useTranslations } from '../../../i18n/utils';

const allPapers = Object.values(import.meta.glob<{ url: string, frontmatter: any }>('../../research/*.md', { eager: true }));
const sortedPapers = allPapers;

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang);
---

<Layout title={`${t('research.title')} | Alberto Maccanico`}>
  <Nav />

  <div id="research-content" class="max-w-5xl mx-auto py-24 sm:py-32 px-4 sm:px-6 min-h-screen relative z-10">
    <div class="mb-10 sm:mb-16 section-fade">
      <div class="mb-8">
        <a href={lang === 'en' ? '/' : `/${lang}`} class="text-text-muted hover:text-accent-blue transition-colors flex items-center gap-2 font-mono text-sm w-fit">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          {t('research.back')}
        </a>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{t('research.title')}</span>
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed max-w-2xl">{t('research.subtitle')}</p>
      <div class="w-16 h-1 bg-gradient-to-r from-accent-blue to-accent-purple rounded-full mt-8"></div>
    </div>

    <div class="grid gap-4 sm:gap-6">
      {sortedPapers.map((paper) => {
        const { title, description, publication, originalUrl } = paper.frontmatter;
        return (
          <a
            href={paper.url}
            class="glass rounded-2xl p-5 sm:p-8 section-fade glow-border group block hover:scale-[1.01] transition-transform cursor-pointer"
          >
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent-blue/20 to-accent-purple/20 flex items-center justify-center group-hover:from-accent-blue/30 group-hover:to-accent-purple/30 transition-colors">
                <svg class="w-6 h-6 text-accent-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611l-.573.097a9.043 9.043 0 01-7.124 0l-.573-.097c-1.717-.293-2.299-2.379-1.067-3.611L5 14.5" />
                </svg>
              </div>
              <div class="flex items-center gap-2">
                {originalUrl && (
                  <span class="text-xs font-mono text-accent-blue bg-accent-blue/10 border border-accent-blue/20 px-2 py-0.5 rounded-full">PDF</span>
                )}
                <svg class="w-4 h-4 text-text-muted group-hover:text-accent-blue transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </div>
            </div>
            <h2 class="font-semibold text-text-primary text-xl md:text-2xl mb-3 group-hover:text-accent-blue transition-colors">{title}</h2>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">{description}</p>
            {publication && <p class="text-text-muted text-xs font-mono">{publication}</p>}
          </a>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const container = document.getElementById('research-content');
  if (container) {
    const faders = container.querySelectorAll('.section-fade');
    gsap.fromTo(faders,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power2.out",
        scrollTrigger: {
          trigger: container,
          start: "top 80%",
        }
      }
    );
  }

  const cards = document.querySelectorAll('.glass:not(#navbar .glass)');
  cards.forEach((card) => {
    const cardEl = card as HTMLElement;
    cardEl.addEventListener('mousemove', (e) => {
      const rect = cardEl.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * 4;
      const rotateY = ((x - centerX) / centerX) * -4;
      cardEl.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.01)`;
      cardEl.style.setProperty('--mouse-x', `${(x / rect.width) * 100}%`);
      cardEl.style.setProperty('--mouse-y', `${(y / rect.height) * 100}%`);
    });
    cardEl.addEventListener('mouseleave', () => {
      cardEl.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
      cardEl.style.transition = 'transform 0.5s ease';
      setTimeout(() => { cardEl.style.transition = 'transform 0.1s ease-out'; }, 500);
    });
  });
</script>
