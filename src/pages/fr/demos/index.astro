---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang);

const demos = [
  {
    title: 'Albert Dashboard',
    description: 'Tableau de bord d\'investissement en temps réel avec graphiques TradingView interactifs.',
    tech: ['React 19', 'TailwindCSS 4'],
    href: '/demos/albert-dashboard/index.html',
    external: true,
  },
  {
    title: 'Codice Fiscale Generator',
    description: 'Calculez un code fiscal italien (Codice Fiscale) avec l\'algorithme officiel, porté de Python vers le web.',
    tech: ['TypeScript', 'Astro'],
    href: '/demos/cfpython',
    external: false,
  },
  {
    title: 'Limited Lands',
    description: 'App compagnon MTG : calculateur de mana, compteur de vies (2–10), deck builder, tournois suisses et ratings 17Lands.',
    tech: ['Flutter', 'Riverpod'],
    href: '/demos/limitedlands',
    external: false,
  },
  {
    title: 'BUS Roma',
    description: 'Horaires de bus et arrivées en temps réel pour tous les arrêts ATAC de Rome, avec Drift SQLite et flux GTFS-RT.',
    tech: ['Flutter', 'Drift SQLite'],
    href: '/demos/bus-roma',
    external: false,
  },
];
---

<Layout title={`${t('demos.title')} | Alberto Maccanico`}>
  <div id="demos-content" class="content-wrapper min-h-screen flex flex-col bg-white">
    <header class="p-6 sm:p-12 lg:p-16 flex flex-col justify-center bauhaus-border-b" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black);">
      <a href={lang === 'en' ? '/' : `/${lang}`} class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-black)] font-bold uppercase mb-8 sm:mb-12 w-fit hover:bg-[var(--bauhaus-white)] hover:text-[var(--bauhaus-black)] transition-colors">
        ← {t('demos.back')}
      </a>
      <h1 class="text-5xl sm:text-7xl lg:text-[8rem] font-black tracking-tighter leading-none mb-6">{t('demos.title')}</h1>
      <p class="text-xl sm:text-3xl lg:text-4xl font-medium max-w-4xl border-l-[8px] border-black pl-6 leading-tight">{t('demos.subtitle')}</p>
    </header>

    <div class="flex-1 flex flex-col">
      {demos.map((demo, i) => {
        const bgs = ['var(--bauhaus-blue)', 'var(--bauhaus-white)', 'var(--bauhaus-red)', 'var(--bauhaus-grey)'];
        const txs = ['var(--bauhaus-white)', 'var(--bauhaus-black)', 'var(--bauhaus-white)', 'var(--bauhaus-black)'];

        const bg = bgs[i % bgs.length];
        const tx = txs[i % txs.length];

        return (
          <a
            href={demo.href}
            target={demo.external ? '_blank' : undefined}
            rel={demo.external ? 'noopener noreferrer' : undefined}
            class="glass block p-6 sm:p-12 lg:p-16 bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row justify-between xl:items-center gap-8 lg:gap-16 hover:opacity-90 transition-opacity"
            style={`background-color: ${bg}; color: ${tx};`}
          >
            <div class="xl:w-2/3">
              <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-4 sm:mb-6 tracking-tight leading-none">{demo.title}</h2>
              <p class="text-xl sm:text-2xl lg:text-3xl font-medium max-w-4xl leading-tight mb-8">{demo.description}</p>

              <div class="flex flex-wrap gap-4">
                {demo.tech.map(tech => (
                  <span class="inline-block px-4 py-2 text-base sm:text-xl font-bold uppercase border-[3px]" style={`border-color: ${tx};`}>
                    {tech}
                  </span>
                ))}
              </div>
            </div>

            <div class="xl:w-1/3 xl:text-right pt-4 xl:pt-0">
              <span class="inline-block px-6 py-4 bg-black text-white text-2xl sm:text-3xl font-black uppercase transition-transform hover:-translate-y-1 w-fit border-[3px] border-white">
                {demo.external ? 'ouvrir externe ↗' : 'ouvrir démo →'}
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
