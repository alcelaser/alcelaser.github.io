---
import Layout from '../layouts/Layout.astro';
import { getCV, useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale || 'en';
const {
  experience,
  education,
  skills,
  awards,
  languages,
  personal
} = getCV(lang);
const t = useTranslations(lang);

const skillCategoryMeta = {
  programming: { label: t('section.skills.cat.programming'), bg: 'var(--bauhaus-blue)',   text: 'var(--bauhaus-white)' },
  ai:          { label: t('section.skills.cat.ai'),          bg: 'var(--bauhaus-red)',    text: 'var(--bauhaus-white)' },
  tools:       { label: t('section.skills.cat.tools'),       bg: 'var(--bauhaus-yellow)', text: 'var(--bauhaus-black)' },
  writing:     { label: t('section.skills.cat.writing'),     bg: 'var(--bauhaus-grey)',   text: 'var(--bauhaus-black)' },
  soft:        { label: t('section.skills.cat.soft'),        bg: 'var(--bauhaus-black)',  text: 'var(--bauhaus-white)' },
} as const;

const skillCategories = (['programming', 'ai', 'tools', 'writing', 'soft'] as const).map(key => ({
  key,
  ...skillCategoryMeta[key],
  items: skills.filter(s => s.category === key),
}));

const titleVariants = personal.title
  .split('|')
  .map((item) => item.trim())
  .filter(Boolean);

const allPosts = Object.values(import.meta.glob<{ url: string, frontmatter: any }>('./blog/*.md', { eager: true }));
const displayedArticles = allPosts.slice(0, 4);

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
}

const fallbackRepos: GitHubRepo[] = [
  {
    name: 'Albert Dashboard',
    description: 'Real-time investment dashboard tracking stocks, crypto, and commodities.',
    html_url: '/demos/albert-dashboard/index.html',
  },
  {
    name: 'Codice Fiscale Generator',
    description: 'Italian tax code generator using the official algorithm in the browser.',
    html_url: '/demos/cfpython',
  },
  {
    name: 'Limited Lands',
    description: 'MTG companion app with mana calculator, life counter, deck builder, and tournament tools.',
    html_url: '/demos/limitedlands',
  },
  {
    name: 'BUS Roma',
    description: 'Real-time ATAC bus arrivals and stop navigation for Rome.',
    html_url: '/demos/bus-roma',
  },
];

let repos: GitHubRepo[] = [];
try {
  const res = await fetch('https://api.github.com/users/alcelaser/repos?sort=updated&per_page=30', {
    headers: { Accept: 'application/vnd.github.v3+json' },
  });
  if (res.ok) {
    const all = await res.json();
    repos = all
      .filter((r: any) => !r.fork && r.name !== 'alcelaser' && r.name !== 'phobiareleased')
      .slice(0, 6);
  }
} catch {}

const projectCards = repos.length > 0 ? repos : fallbackRepos;
---
<Layout title={personal.name} description={personal.summary}>

  <div class="content-wrapper min-h-screen relative overflow-hidden">
    
    <!-- HEADER -->
    <header class="bauhaus-border-b flex flex-col md:flex-row min-h-[60vh]">
      
      <div id="hero-playground" class="flex-1 p-8 sm:p-12 lg:p-16 flex flex-col justify-center relative overflow-hidden" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black); border-bottom: var(--line-weight) solid var(--bauhaus-black); border-right: var(--line-weight) solid var(--bauhaus-black);">
        <h1 id="hero-name" class="huge-text mb-6 tracking-tight block">
          <span class="hero-name-part" data-collision-target="albert">{personal.name.split(' ')[0].slice(0, -1)}</span><span id="hero-ball-o" class="hero-ball-letter">o</span><br/><span class="hero-name-part" data-collision-target="maccanico">{personal.name.split(' ')[1]}</span>
        </h1>
        <h2 class="large-text typewriter-container">
          <span id="hero-typewriter" data-positions={JSON.stringify(titleVariants)}>{titleVariants[0] ?? personal.title}</span>
        </h2>
      </div>

      <!-- Outbound Initial Links (User Request) -->
      <nav class="bauhaus-link-stagger md:w-[450px] flex flex-col bauhaus-border-t md:bauhaus-border-t-0 md:bauhaus-border-l shrink-0 bg-white">
        <a href={`mailto:${personal.email}`} class="bauhaus-link" style="background-color: var(--bauhaus-red); color: white;">
          <span class="kinetic-clip hero-nav-label">{t('hero.contact')}</span> <span class="bauhaus-link-arrow">↗</span>
        </a>
        <a href={personal.linkedin} target="_blank" class="bauhaus-link">
          <span class="kinetic-clip hero-nav-label">linkedin</span> <span class="bauhaus-link-arrow">↗</span>
        </a>
        <a href={personal.github} target="_blank" class="bauhaus-link">
          <span class="kinetic-clip hero-nav-label">github</span> <span class="bauhaus-link-arrow">↗</span>
        </a>
        <a href={lang === 'en' ? '/blog' : `/${lang}/blog`} class="bauhaus-link">
          <span class="kinetic-clip hero-nav-label">{t('hero.readBlog')}</span> <span class="bauhaus-link-arrow">→</span>
        </a>
        <a href={lang === 'en' ? '/demos' : `/${lang}/demos`} class="bauhaus-link">
          <span class="kinetic-clip hero-nav-label">{t('hero.projects')}</span> <span class="bauhaus-link-arrow">→</span>
        </a>
      </nav>

    </header>

    <!-- ABOUT ACCORDION -->
    <section id="about" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-black); color: var(--bauhaus-white);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.about')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="p-8 sm:p-12 lg:p-16 flex flex-col justify-center">
          <p class="text-3xl sm:text-4xl md:text-[2.5rem] leading-tight font-bold text-black" set:html={t('about.desc1') || personal.summary}></p>
          <div class="mt-10 sm:mt-12 grid grid-cols-2 gap-4 sm:gap-8 lg:gap-12">
            <div class="min-w-0">
              <h3 class="text-base sm:text-2xl lg:text-3xl font-black uppercase mb-3 sm:mb-5 text-black">Fluent Languages</h3>
              <div class="flex flex-wrap gap-2 sm:gap-4">
                <a href="/it" class="inline-block px-3 sm:px-5 py-2 sm:py-3 text-sm sm:text-xl lg:text-2xl font-black uppercase border-[3px] border-black shadow-[4px_4px_0px_#000] sm:shadow-[6px_6px_0px_#000] hover:-translate-y-0.5 transition-transform" style="background-color: var(--bauhaus-red); color: var(--bauhaus-white);">Italian</a>
                <a href="/" class="inline-block px-3 sm:px-5 py-2 sm:py-3 text-sm sm:text-xl lg:text-2xl font-black uppercase border-[3px] border-black shadow-[4px_4px_0px_#000] sm:shadow-[6px_6px_0px_#000] hover:-translate-y-0.5 transition-transform" style="background-color: var(--bauhaus-blue); color: var(--bauhaus-white);">English</a>
                <a href="/fr" class="inline-block px-3 sm:px-5 py-2 sm:py-3 text-sm sm:text-xl lg:text-2xl font-black uppercase border-[3px] border-black shadow-[4px_4px_0px_#000] sm:shadow-[6px_6px_0px_#000] hover:-translate-y-0.5 transition-transform" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black);">French</a>
              </div>
            </div>
            <div class="min-w-0 flex flex-col items-end">
              <h3 class="text-base sm:text-2xl lg:text-3xl font-black uppercase mb-3 sm:mb-5 text-black text-right">Intermediate</h3>
              <div class="flex flex-wrap gap-2 sm:gap-4 justify-end">
                <span class="inline-block px-3 sm:px-5 py-2 sm:py-3 text-sm sm:text-xl lg:text-2xl font-black uppercase border-[3px] border-black shadow-[4px_4px_0px_#000] sm:shadow-[6px_6px_0px_#000]" style="background-color: var(--bauhaus-white); color: var(--bauhaus-black);">Spanish</span>
                <span class="inline-block px-3 sm:px-5 py-2 sm:py-3 text-sm sm:text-xl lg:text-2xl font-black uppercase border-[3px] border-black shadow-[4px_4px_0px_#000] sm:shadow-[6px_6px_0px_#000]" style="background-color: var(--bauhaus-white); color: var(--bauhaus-black);">German</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS ACCORDION -->
    <section id="skills" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-blue); color: var(--bauhaus-white);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.skills')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bg-[#F5F5F5] bauhaus-border-t">
        <div class="flex flex-col p-8 sm:p-12 lg:p-16 gap-5">
          {skillCategories.map(cat => (
            <div class="skill-category-block">
              <button
                class="skill-cat-trigger w-full flex items-center justify-between px-6 sm:px-10 py-6 sm:py-8 uppercase font-black text-3xl sm:text-4xl lg:text-5xl border-[var(--line-weight)] border-[var(--bauhaus-black)] shadow-[6px_6px_0px_#000] cursor-pointer transition-transform hover:-translate-y-0.5"
                style={`background-color: ${cat.bg}; color: ${cat.text};`}
                data-category={cat.key}
              >
                <span>{cat.label}</span>
                <span class="skill-cat-icon font-black leading-none transition-transform duration-300 text-5xl sm:text-6xl lg:text-7xl">+</span>
              </button>
              <div class="skill-chips-wrap overflow-hidden" style="height: 0;">
                <div class="skill-chips-inner flex flex-wrap gap-3 sm:gap-4 p-6 sm:p-8 bg-white" style="border: var(--line-weight) solid var(--bauhaus-black); border-top: none;">
                  {cat.items.map(s => (
                    <span
                      class="skill-chip uppercase font-black px-4 sm:px-5 py-2 sm:py-3 text-lg sm:text-xl lg:text-2xl shadow-[4px_4px_0px_#000]"
                      style={`border: 3px solid var(--bauhaus-black); background-color: ${cat.bg}; color: ${cat.text};`}
                    >
                      {s.name}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- EXPERIENCE ACCORDION -->
    <section id="experience" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-red); color: var(--bauhaus-white);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.experience')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="flex flex-col">
          {experience.map((exp, i) => (
            <article class="p-8 sm:p-12 lg:p-16 bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row gap-8 lg:gap-16 bg-white hover-row transition-transform duration-300">
              <div class="xl:w-1/3 shrink-0">
                <h3 class="text-4xl md:text-5xl font-black mb-4 uppercase leading-none tracking-tight">{exp.role}</h3>
                <span class="inline-block px-4 py-2 bg-black text-white font-bold text-2xl md:text-3xl leading-none shadow-[6px_6px_0px_#D3D3D3]">{exp.company}</span>
                <p class="mt-8 text-2xl font-bold font-mono text-gray-700 bg-[var(--bauhaus-yellow)] w-fit px-2 border-[3px] border-black">{exp.period}</p>
              </div>
              <div class="xl:w-2/3">
                <ul class="list-square pl-6 text-2xl md:text-[1.75rem] leading-snug font-medium space-y-6">
                  {exp.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- EDUCATION ACCORDION -->
    <section id="education" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-grey); color: var(--bauhaus-black);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.education')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="flex flex-col">
          {education.map((edu, i) => (
            <article class="p-8 sm:p-12 lg:p-16 bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row gap-8 lg:gap-16 bg-white hover-row transition-transform duration-300">
              <div class="xl:w-1/3 shrink-0">
                <h3 class="text-4xl md:text-5xl font-black mb-4 uppercase leading-none tracking-tight">{edu.degree}</h3>
                <span class="inline-block px-4 py-2 bg-black text-white font-bold text-2xl md:text-3xl leading-none shadow-[6px_6px_0px_#D3D3D3]">{edu.institution}</span>
                {edu.period && <p class="mt-8 text-2xl font-bold font-mono text-gray-700 bg-[var(--bauhaus-yellow)] w-fit px-2 border-[3px] border-black">{edu.period}</p>}
                {edu.location && <p class="mt-4 text-xl font-bold uppercase tracking-widest text-[#555]">{edu.location}</p>}
              </div>
              <div class="xl:w-2/3">
                {edu.details && edu.details.length > 0 && (
                  <ul class="list-square pl-6 text-2xl md:text-[1.75rem] leading-snug font-medium space-y-6">
                    {edu.details.map((d: string) => <li>{d}</li>)}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PROJECTS ACCORDION -->
    <section id="projects" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-yellow); color: var(--bauhaus-black);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.projects')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="flex flex-wrap bg-white">
          {projectCards.map((r, i) => {
            const bgs = ['var(--bauhaus-white)', 'var(--bauhaus-yellow)', 'var(--bauhaus-blue)', 'var(--bauhaus-grey)', 'var(--bauhaus-white)', 'var(--bauhaus-red)'];
            const textCols = ['var(--bauhaus-black)', 'var(--bauhaus-black)', 'var(--bauhaus-white)', 'var(--bauhaus-black)', 'var(--bauhaus-black)', 'var(--bauhaus-white)'];
            
            let bg = bgs[i % bgs.length];
            let tx = textCols[i % textCols.length];
            
            return (
               <a href={r.html_url} target="_blank" class="w-full md:w-1/2 p-8 sm:p-12 lg:p-16 flex flex-col hover-row-red min-h-[400px]" style={`background-color: ${bg}; color: ${tx}; border-bottom: var(--line-weight) solid var(--bauhaus-black); border-right: var(--line-weight) solid var(--bauhaus-black); margin-bottom: -5px; margin-right: -5px;`}>
                 <h3 class="text-4xl lg:text-5xl font-black mb-6 leading-none tracking-tight">{r.name}</h3>
                 <p class="text-2xl font-medium leading-relaxed flex-1">{r.description || 'github repository'}</p>
                 <div class="mt-8">
                   <span class="inline-block px-4 py-2 text-2xl font-bold uppercase border-2 focus:outline-none" style={`border-color: ${tx};`}>repository ↗</span>
                 </div>
               </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- AWARDS ACCORDION -->
    <section id="awards" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-blue); color: var(--bauhaus-white);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.awards')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="flex flex-wrap bg-white">
          {awards.map((award, i) => {
            const bgs = ['var(--bauhaus-white)', 'var(--bauhaus-yellow)', 'var(--bauhaus-blue)', 'var(--bauhaus-grey)', 'var(--bauhaus-white)', 'var(--bauhaus-red)'];
            const textCols = ['var(--bauhaus-black)', 'var(--bauhaus-black)', 'var(--bauhaus-white)', 'var(--bauhaus-black)', 'var(--bauhaus-black)', 'var(--bauhaus-white)'];
            
            let bg = bgs[(i+2) % bgs.length];
            let tx = textCols[(i+2) % textCols.length];
            
            if (award.title.includes('Model United Nations')) {
              bg = 'var(--bauhaus-blue)';
              tx = 'var(--bauhaus-white)';
            }
            
            return (
              <div class="w-full md:w-1/2 p-8 sm:p-12 lg:p-16 flex flex-col hover-row-red min-h-[300px]" style={`background-color: ${bg}; color: ${tx}; border-bottom: var(--line-weight) solid var(--bauhaus-black); border-right: var(--line-weight) solid var(--bauhaus-black); margin-bottom: -5px; margin-right: -5px;`}>
                <h3 class="text-4xl lg:text-5xl font-black mb-6 leading-none tracking-tight">{award.title}</h3>
                <p class="text-2xl font-bold uppercase">{award.issuer}</p>
                {award.detail && <p class="text-2xl font-medium leading-relaxed flex-1 mt-4">{award.detail}</p>}
                {award.url && (
                  <div class="mt-8">
                    <a href={award.url} target="_blank" rel="noreferrer noopener" class="inline-block px-6 py-3 border-2 border-black font-black uppercase text-xl transition-transform hover:-translate-y-1 shadow-[6px_6px_0px_#000]" style="background-color: var(--bauhaus-white); color: var(--bauhaus-black);">
                      Link ↗
                    </a>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ARTICLES ACCORDION -->
    <section id="articles" class="bauhaus-border-b flex flex-col bg-white">
      <div class="accordion-trigger p-6 sm:p-12 lg:p-16 flex flex-row justify-between items-center cursor-pointer transition-colors" style="background-color: var(--bauhaus-black); color: var(--bauhaus-white);">
        <h2 class="huge-text pointer-events-none mb-0 leading-none kinetic-clip section-heading-kinetic">{t('nav.articles')}</h2>
        <div class="accordion-icon text-[4rem] sm:text-[6rem] lg:text-[10rem] font-black leading-none pointer-events-none transition-transform duration-500">+</div>
      </div>
      <div class="accordion-content overflow-hidden bauhaus-border-t">
        <div class="flex flex-col">
          {displayedArticles.map(post => (
            <a href={post.url} class="block p-8 sm:p-12 lg:p-16 hover-row-red bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row justify-between gap-8 xl:items-center bg-white text-black">
              <div class="xl:w-2/3">
                <h3 class="text-5xl lg:text-6xl xl:text-7xl font-black mb-6 tracking-tighter leading-none">{post.frontmatter.title}</h3>
                <p class="text-2xl font-medium max-w-3xl leading-snug">{post.frontmatter.description}</p>
              </div>
              <div class="xl:w-1/3 xl:text-right pt-4 xl:pt-0">
                 <span class="inline-block px-6 py-4 bg-black text-white text-3xl font-black uppercase transition-transform hover:-translate-y-1 shadow-[8px_8px_0px_#FFFF00]">read ↗</span>
              </div>
            </a>
          ))}
          <div class="p-8 sm:p-12 lg:p-16 bg-white flex justify-center hover-row-red bauhaus-border-t mt-[-5px]">
             <a href="/blog" class="text-3xl md:text-5xl font-black text-black uppercase">view all articles →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER LINKS -->
    <footer class="flex flex-col bg-white">
       <a href="#top" class="block w-full p-12 lg:p-16 text-center text-4xl sm:text-5xl md:text-7xl font-black uppercase tracking-tight hover-row-red">
         back to top ↑
       </a>
    </footer>

  </div>

</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { prepare, layout } from '@chenglou/pretext';
  
  gsap.registerPlugin(ScrollTrigger);

  // --- Hero nav labels: kinetic char-split stagger ---
  function splitToChars(el: HTMLElement) {
    const text = el.innerText;
    el.innerHTML = '';
    text.split('').forEach(ch => {
      const s = document.createElement('span');
      s.className = 'char';
      s.innerHTML = ch === ' ' ? '&nbsp;' : ch;
      el.appendChild(s);
    });
  }

  document.querySelectorAll<HTMLElement>('.hero-nav-label').forEach(label => splitToChars(label));

  // Animate each label's chars with a per-label offset so they pop in row by row
  document.querySelectorAll<HTMLElement>('.hero-nav-label').forEach((label, rowIndex) => {
    gsap.to(label.querySelectorAll('.char'), {
      y: 0,
      duration: 0.6,
      ease: 'power4.out',
      stagger: 0.03,
      delay: 0.1 + rowIndex * 0.12,
    });
  });

  // --- Section headings: kinetic char-split stagger ---
  document.querySelectorAll<HTMLElement>('.section-heading-kinetic').forEach((heading, headingIndex) => {
    splitToChars(heading);
    gsap.to(heading.querySelectorAll('.char'), {
      y: 0,
      duration: 0.7,
      ease: 'power4.out',
      stagger: 0.025,
      delay: 0.2 + headingIndex * 0.08,
    });
  });

  // --- Scroll Animations ---
    // --- Skill category explode ---
    document.querySelectorAll<HTMLElement>('.skill-cat-trigger').forEach(trigger => {
      const block = trigger.closest('.skill-category-block') as HTMLElement;
      const wrap = block.querySelector<HTMLElement>('.skill-chips-wrap')!;
      const icon = trigger.querySelector<HTMLElement>('.skill-cat-icon')!;
      let open = false;

      trigger.addEventListener('click', () => {
        if (!open) {
          open = true;
          gsap.to(icon, { rotation: 45, duration: 0.3, ease: 'power2.out' });
          gsap.to(wrap, { height: 'auto', duration: 0.4, ease: 'power3.out' });
          const chips = wrap.querySelectorAll<HTMLElement>('.skill-chip');
          gsap.fromTo(chips,
            { scale: 0, opacity: 0 },
            { scale: 1, opacity: 1, duration: 0.45, ease: 'back.out(2)', stagger: { amount: 0.45, from: 'center' }, delay: 0.15 }
          );
        } else {
          open = false;
          gsap.to(icon, { rotation: 0, duration: 0.3, ease: 'power2.out' });
          gsap.to(wrap, { height: 0, duration: 0.35, ease: 'power3.inOut' });
        }
      });
    });

  const sections = gsap.utils.toArray('.anim-slide-up');
  sections.forEach((sec: any) => {
    gsap.fromTo(sec, 
      { opacity: 0, y: 100 }, 
      { opacity: 1, y: 0, duration: 1, ease: "power3.out", scrollTrigger: { trigger: sec, start: "top 85%" } }
    );
  });

  // --- Absolute Parallax Shapes ---
  gsap.utils.toArray('.geom-shape').forEach((shape: any) => {
    const speed = parseFloat(shape.getAttribute('data-speed'));
    
    // Animate across the fixed viewport relative to total document scroll
    gsap.fromTo(shape, 
      { y: 0 },
      {
        y: () => -window.innerHeight * speed,
        ease: "none",
        scrollTrigger: {
          trigger: document.body,
          start: "top top",
          end: "bottom bottom",
          scrub: true
        }
      }
    );
    
    // Smooth endless rotating circle for red shape
    if (shape.classList.contains('shape-red')) {
      gsap.to(shape, {
        rotation: 360,
        ease: "none",
        scrollTrigger: {
          trigger: shape,
          start: "top bottom",
          end: "bottom top",
          scrub: 1.5
        }
      });
    }
  });

  // --- Hero subtitle typewriter (write / backspace / next position) ---
  // Uses @chenglou/pretext to pre-measure all title variants and set a stable
  // min-height on the container, preventing layout shift during typing.
  const typewriter = document.getElementById('hero-typewriter');
  if (typewriter) {
    let positions: string[] = [];
    try {
      positions = JSON.parse(typewriter.getAttribute('data-positions') || '[]');
    } catch {
      positions = [];
    }

    if (positions.length > 1) {
      // --- Pretext: stabilise typewriter height ---
      // Compute the font size at the current viewport to match the CSS clamp().
      // large-text class: font-size: clamp(2rem, 5vw, 4rem)
      const vw5 = window.innerWidth * 0.05;
      const computedFontSize = Math.max(32, Math.min(vw5, 64)); // 2rem=32px, 4rem=64px
      const lineHeight = computedFontSize * 1.1; // matches heading line-height
      const font = `900 ${computedFontSize}px "Product Sans", sans-serif`;
      const containerWidth = typewriter.parentElement?.clientWidth || window.innerWidth;

      // Measure every variant with pretext and find the tallest
      let maxHeight = lineHeight; // at minimum one line
      for (const variant of positions) {
        try {
          const prepared = prepare(variant, font);
          const measured = layout(prepared, containerWidth, lineHeight);
          if (measured.height > maxHeight) maxHeight = measured.height;
        } catch {
          // Graceful fallback if pretext can't measure (e.g. font not loaded yet)
        }
      }

      // Lock the container height so it never shifts during typing
      typewriter.style.minHeight = `${Math.ceil(maxHeight)}px`;
      typewriter.style.display = 'block';

      let positionIndex = 0;
      let charIndex = 0;
      let isDeleting = false;

      const typeDelay = 90;
      const deleteDelay = 45;
      const holdDelay = 1200;

      const tick = () => {
        // Stop ticking if the ball has been detached
        if ((window as any).__heroBallDetached) return;
        const current = positions[positionIndex] || '';

        if (isDeleting) {
          charIndex = Math.max(0, charIndex - 1);
        } else {
          charIndex = Math.min(current.length, charIndex + 1);
        }

        const visibleText = current.slice(0, charIndex);
        // Render words as nowrap groups so wrapping only happens between words.
        typewriter.innerHTML = '';
        if (visibleText.length > 0) {
          const tokens = visibleText.split(/(\s+)/);
          for (const token of tokens) {
            if (!token) continue;
            if (/^\s+$/.test(token)) {
              typewriter.appendChild(document.createTextNode(token.replace(/ /g, '\u00A0')));
              continue;
            }

            const word = document.createElement('span');
            word.className = 'typewriter-word';
            for (const ch of token) {
              const span = document.createElement('span');
              span.className = 'typewriter-char';
              span.textContent = ch;
              word.appendChild(span);
            }
            typewriter.appendChild(word);
          }
        } else {
          typewriter.textContent = '\u00A0';
        }

        if (!isDeleting && charIndex === current.length) {
          isDeleting = true;
          window.setTimeout(tick, holdDelay);
          return;
        }

        if (isDeleting && charIndex === 0) {
          isDeleting = false;
          positionIndex = (positionIndex + 1) % positions.length;
          window.setTimeout(tick, 250);
          return;
        }

        window.setTimeout(tick, isDeleting ? deleteDelay : typeDelay);
      };

      typewriter.textContent = '\u00A0';
      window.setTimeout(tick, 300);
    }
  }

  // ==========================================================================
  // HERO BALL PHYSICS — the 'o' from alberto becomes a throwable letter
  // All typewriter chars also become bouncing bodies on detach.
  // ==========================================================================
  const heroBall = document.getElementById('hero-ball-o') as HTMLElement;
  const playground = document.getElementById('hero-playground') as HTMLElement;

  if (heroBall && playground) {
    // --- State ---
    let detached = false;
    let dragging = false;
    let bx = 0, by = 0;       // ball center (relative to playground)
    let bvx = 0, bvy = 0;     // ball velocity px/s
    let ballW = 0, ballH = 0; // measured char dimensions

    const mouseHist: { x: number; y: number; t: number }[] = [];

    // --- Constants ---
    const BASE_GRAVITY = 900;
    let gravityX       = 0;
    let gravityY       = BASE_GRAVITY;
    const RESTITUTION  = 0.55;
    const AIR_DRAG     = 0.997;
    const FLOOR_FRIC   = 0.90;
    const REST_THRESH  = 10;
    const MAX_V        = 2500;

    // --- Device Orientation ---
    if (typeof window !== 'undefined' && window.DeviceOrientationEvent) {
      window.addEventListener('deviceorientation', (e) => {
        if (e.beta !== null && e.gamma !== null) {
          let gx = e.gamma;
          let gy = e.beta;
          
          let orientation = window.screen?.orientation?.angle || (window as any).orientation || 0;
          if (orientation === 90) {
            let tmp = gx; gx = gy; gy = -tmp;
          } else if (orientation === -90 || orientation === 270) {
            let tmp = gx; gx = -gy; gy = tmp;
          } else if (orientation === 180) {
            gx = -gx; gy = -gy;
          }

          if (gx > 90) gx = 90;
          if (gx < -90) gx = -90;
          if (gy > 90) gy = 90;
          if (gy < -90) gy = -90;

          gravityX = (gx / 90) * BASE_GRAVITY * 1.5;
          gravityY = (gy / 90) * BASE_GRAVITY * 1.5;
        }
      });
    }

    // --- Physics bodies (typewriter letters) ---
    interface Body {
      el: HTMLElement;
      x: number; y: number;
      vx: number; vy: number;
      w: number; h: number;
      rot: number; rotV: number;
    }
    
    interface StaticBody {
      x: number; y: number;
      w: number; h: number;
    }
    
    const bodies: Body[] = [];
    const staticBodies: StaticBody[] = [];

    function pgBounds() {
      return { w: playground.clientWidth, h: playground.clientHeight };
    }

    // --- Detach: keep the 'o' looking like text, convert typewriter chars ---
    function detach() {
      if (detached) return;
      detached = true;

      // Freeze the typewriter immediately
      (window as any).__heroBallDetached = true;

      // Unscale momentarily to capture true physical dimensions without hover scaling
      heroBall.style.transform = 'none';
      const oRect  = heroBall.getBoundingClientRect();
      const pgRect = playground.getBoundingClientRect();
      const h1     = document.getElementById('hero-name');
      const h1Style = h1 ? window.getComputedStyle(h1) : null;

      // Record real character dimensions
      ballW = oRect.width;
      ballH = oRect.height;
      heroBall.style.transform = '';

      // Record centre position. Offset 'by' downwards to match the optical center of the lowercase 'o' ink.
      bx = oRect.left - pgRect.left + ballW / 2;
      by = oRect.top  - pgRect.top  + ballH * 0.55;

      // Reparent to playground, keep text appearance
      const fontSize = h1Style ? h1Style.fontSize : '3rem';
      heroBall.remove();
      playground.appendChild(heroBall);

      heroBall.className = 'hero-ball-text';
      heroBall.style.position  = 'absolute';
      heroBall.style.left      = `${bx - ballW / 2}px`;
      heroBall.style.top       = `${by - ballH * 0.55}px`;
      heroBall.style.fontSize  = fontSize;
      heroBall.style.cursor    = 'grab';
      heroBall.style.zIndex    = '100';
      heroBall.style.transition = 'none';

      // Create static collision bodies for the rest of the name (albert, maccanico)
      createStaticNameColliders(pgRect);
    }

    function createStaticNameColliders(pgRect: DOMRect) {
      const namePartElements = document.querySelectorAll<HTMLElement>('.hero-name-part');
      namePartElements.forEach(part => {
        const text = part.textContent || '';
        // Wrap each character in a span for per-character collision
        const chars: HTMLElement[] = [];
        part.innerHTML = '';
        for (const char of text) {
          const charSpan = document.createElement('span');
          charSpan.className = 'name-char-collision';
          charSpan.textContent = char;
          part.appendChild(charSpan);
          chars.push(charSpan);
        }
        
        // Create collision body for each character
        for (const charEl of chars) {
          const rect = charEl.getBoundingClientRect();
          const x = rect.left - pgRect.left + rect.width / 2;
          const y = rect.top - pgRect.top + rect.height * 0.55;
          
          staticBodies.push({
            x: x,
            y: y,
            w: rect.width,
            h: rect.height,
          });
        }
      });
    }

    // --- Drag ---
    function grabBall(cx: number, cy: number) {
      dragging = true;
      heroBall.style.cursor = 'grabbing';
      mouseHist.length = 0;
      bvx = 0; bvy = 0;
      recordMouse(cx, cy);
    }

    function recordMouse(cx: number, cy: number) {
      const pgRect = playground.getBoundingClientRect();
      mouseHist.push({ x: cx - pgRect.left, y: cy - pgRect.top, t: performance.now() });
      if (mouseHist.length > 6) mouseHist.shift();
    }

    function moveBall(cx: number, cy: number) {
      if (!dragging) return;
      recordMouse(cx, cy);
      const pgRect = playground.getBoundingClientRect();
      bx = cx - pgRect.left;
      by = cy - pgRect.top;
      heroBall.style.left = `${bx - ballW / 2}px`;
      heroBall.style.top  = `${by - ballH * 0.55}px`;
    }

    function releaseBall() {
      if (!dragging) return;
      dragging = false;
      heroBall.style.cursor = 'grab';
      if (mouseHist.length >= 2) {
        const a = mouseHist[0];
        const b = mouseHist[mouseHist.length - 1];
        const dt = (b.t - a.t) / 1000;
        if (dt > 0.005) {
          bvx = Math.max(-MAX_V, Math.min(MAX_V, (b.x - a.x) / dt));
          bvy = Math.max(-MAX_V, Math.min(MAX_V, (b.y - a.y) / dt));
        }
      }
    }

    // --- Events ---
    heroBall.addEventListener('mousedown', e => {
      e.preventDefault(); if (!detached) detach(); grabBall(e.clientX, e.clientY);
    });
    heroBall.addEventListener('touchstart', e => {
      e.preventDefault(); if (!detached) detach(); grabBall(e.touches[0].clientX, e.touches[0].clientY);
    }, { passive: false });
    window.addEventListener('mousemove', e => moveBall(e.clientX, e.clientY));
    window.addEventListener('touchmove', e => {
      if (dragging) { e.preventDefault(); moveBall(e.touches[0].clientX, e.touches[0].clientY); }
    }, { passive: false });
    window.addEventListener('mouseup',  () => releaseBall());
    window.addEventListener('touchend', () => releaseBall());

    // --- Ball-to-body collision ---
    function ballHitsBodies() {
      const br = ballW * 0.45; // Tight visual radius for the 'o'
      
      // Collide with dynamic bodies
      for (const b of bodies) {
        const dr = b.w * 0.35; // Tighter hit radius matching the inner ink better
        const dx = bx - b.x;
        const dy = by - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const minD = br + dr;
        if (dist < minD && dist > 0.1) {
          // Push the char away from the ball
          const nx = dx / dist;
          const ny = dy / dist;
          const relVx = bvx - b.vx;
          const relVy = bvy - b.vy;
          const impactSpeed = relVx * (-nx) + relVy * (-ny);
          if (impactSpeed > 0) {
            const impulse = impactSpeed * 1.4;
            b.vx += -nx * impulse;
            b.vy += -ny * impulse;
            b.rotV += (Math.random() - 0.5) * impulse * 1.5;
            // Slight pushback on the ball
            bvx -= -nx * impulse * 0.15;
            bvy -= -ny * impulse * 0.15;
          }
          // Separate
          const overlap = minD - dist;
          b.x -= nx * overlap;
          b.y -= ny * overlap;
        }
      }
      
      // Collide with static bodies (name parts)
      for (const sb of staticBodies) {
        const sr = sb.w * 0.75; // Wider radius to prevent bodies falling through gaps
        const dx = bx - sb.x;
        const dy = by - sb.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const minD = br + sr;
        
        if (dist < minD && dist > 0.1) {
          // Calculate collision normal
          const nx = dx / dist;
          const ny = dy / dist;
          
          // Bounce the ball - reflect velocity
          const dotProd = bvx * nx + bvy * ny;
          bvx = (bvx - 2 * dotProd * nx) * 0.9; // 0.9 for some damping
          bvy = (bvy - 2 * dotProd * ny) * 0.9;
          
          // Push ball away from static body
          const overlap = minD - dist;
          bx += nx * overlap;
          by += ny * overlap;
        }
      }
    }

    function bodyHitsStaticNameBodies(b: Body) {
      for (const sb of staticBodies) {
        const br = b.w * 0.5; // Tighter hit radius matching the inner ink better
        const sr = sb.w * 0.75; // Wider radius to prevent bodies falling through gaps
        const dx = b.x - sb.x;
        const dy = b.y - sb.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const minD = br + sr;

        if (dist < minD && dist > 0.1) {
          const nx = dx / dist;
          const ny = dy / dist;
          const relVx = b.vx;
          const relVy = b.vy;
          const impactSpeed = relVx * (-nx) + relVy * (-ny);

          if (impactSpeed > 0) {
            const impulse = impactSpeed * 1.3; // Give it a nice bounce
            b.vx += nx * impulse;
            b.vy += ny * impulse;
            b.rotV += (Math.random() - 0.5) * impulse * 1.2;
          }

          const overlap = minD - dist;
          b.x += nx * overlap;
          b.y += ny * overlap;
        }
      }
    }

    // --- Bounce a body off walls ---
    function bounceBody(b: Body, w: number, h: number) {
      const rw = b.w / 2;
      const rh = b.h * 0.45; // Optical bounds ignoring DOM leading
      if (b.x - rw < 0)     { b.x = rw;     b.vx =  Math.abs(b.vx) * RESTITUTION; b.vy *= FLOOR_FRIC; b.rotV *= FLOOR_FRIC; }
      if (b.x + rw > w)     { b.x = w - rw; b.vx = -Math.abs(b.vx) * RESTITUTION; b.vy *= FLOOR_FRIC; b.rotV *= FLOOR_FRIC; }
      if (b.y - rh < 0)     { b.y = rh;     b.vy =  Math.abs(b.vy) * RESTITUTION; b.vx *= FLOOR_FRIC; b.rotV *= FLOOR_FRIC; }
      if (b.y + rh > h)     { b.y = h - rh; b.vy = -Math.abs(b.vy) * RESTITUTION; b.vx *= FLOOR_FRIC; b.rotV *= FLOOR_FRIC; }
    }

    // --- Physics loop ---
    let lastPhysT = performance.now();

    function physicsTick() {
      const now = performance.now();
      const dt = Math.min((now - lastPhysT) / 1000, 0.04);
      lastPhysT = now;
      const { w, h } = pgBounds();

      // --- Ball ('o') ---
      if (detached && !dragging) {
        const visualR = ballW * 0.45; // Precise visual circle of the "o"

        bvy += BASE_GRAVITY * dt;
        bvx *= AIR_DRAG;
        bvy *= AIR_DRAG;
        bx  += bvx * dt;
        by  += bvy * dt;

        if (bx - visualR < 0)     { bx = visualR;     bvx =  Math.abs(bvx) * RESTITUTION; }
        if (bx + visualR > w)     { bx = w - visualR; bvx = -Math.abs(bvx) * RESTITUTION; }
        if (by - visualR < 0)     { by = visualR;     bvy =  Math.abs(bvy) * RESTITUTION; }
        if (by + visualR > h)     { by = h - visualR; bvy = -Math.abs(bvy) * RESTITUTION; bvx *= FLOOR_FRIC; }

        if (Math.abs(bvx) < REST_THRESH && Math.abs(bvy) < REST_THRESH && by + visualR >= h - 2) {
          bvx = 0; bvy = 0;
        }

        heroBall.style.left = `${bx - ballW / 2}px`;
        heroBall.style.top  = `${by - ballH * 0.55}px`;

        // Collide with already-freed letter bodies
        ballHitsBodies();

        // Collide with still-static typewriter chars — knock them free on hit
        knockStaticChars();
      }

      // --- Bouncing typewriter chars integration and wall bounce ---
      for (const b of bodies) {
        b.vx += gravityX * dt;
        b.vy += gravityY * dt;
        b.vx *= AIR_DRAG;
        b.vy *= AIR_DRAG;
        b.x  += b.vx * dt;
        b.y  += b.vy * dt;
        b.rot += b.rotV * dt;
        b.rotV *= 0.90; // fast decay, halts spinning smoothly around ~1s

        bodyHitsStaticNameBodies(b);

        bounceBody(b, w, h);
      }

      // --- Body-to-body collision ---
      for (let i = 0; i < bodies.length; i++) {
        for (let j = i + 1; j < bodies.length; j++) {
          const b1 = bodies[i];
          const b2 = bodies[j];
          const dx = b1.x - b2.x;
          const dy = b1.y - b2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const minD = b1.w * 0.35 + b2.w * 0.35; // Tighter hit radius for letters hitting each other

          if (dist < minD && dist > 0.1) {
            const nx = dx / dist;
            const ny = dy / dist;
            const relVx = b1.vx - b2.vx;
            const relVy = b1.vy - b2.vy;
            const impactSpeed = relVx * (-nx) + relVy * (-ny);
            
            if (impactSpeed > 0) {
              const impulse = impactSpeed * 0.8;
              b1.vx += nx * impulse;
              b1.vy += ny * impulse;
              b2.vx -= nx * impulse;
              b2.vy -= ny * impulse;

              b1.rotV += (Math.random() - 0.5) * impulse * 1.5;
              b2.rotV += (Math.random() - 0.5) * impulse * 1.5;
            }

            // Positional separation to prevent sinking into each other
            const overlap = (minD - dist) * 0.5;
            b1.x += nx * overlap;
            b1.y += ny * overlap;
            b2.x -= nx * overlap;
            b2.y -= ny * overlap;
          }
        }
      }

      // --- Body resting checks and rendering ---
      for (const b of bodies) {
        // Come to rest
        if (Math.abs(b.vx) < 4 && Math.abs(b.vy) < 4) {
          const againstBottom = b.y + b.h * 0.45 >= h - 2 && gravityY > 0;
          const againstTop    = b.y - b.h * 0.45 <= 2     && gravityY < 0;
          const againstRight  = b.x + b.w / 2 >= w - 2 && gravityX > 0;
          const againstLeft   = b.x - b.w / 2 <= 2     && gravityX < 0;
          if (againstBottom || againstTop || againstRight || againstLeft) {
            b.vx = 0; b.vy = 0; b.rotV = 0;
          }
        }

        b.el.style.left = `${b.x - b.w / 2}px`;
        b.el.style.top  = `${b.y - b.h * 0.55}px`;
        b.el.style.transform = `rotate(${b.rot}deg)`;
      }

      requestAnimationFrame(physicsTick);
    }

    // --- Knock static typewriter chars free on collision with 'o' ---
    function knockStaticChars() {
      const chars = document.querySelectorAll<HTMLElement>('.typewriter-char');
      if (chars.length === 0) return;
      const pgRect = playground.getBoundingClientRect();
      const br = ballW * 0.45; // Precise visual radius for 'o'
      const twEl = document.getElementById('hero-typewriter');
      const twFontSize = twEl ? window.getComputedStyle(twEl).fontSize : '2rem';

      chars.forEach(ch => {
        if (ch.dataset.freed === '1') return;
        const cr = ch.getBoundingClientRect();
        const cx = cr.left - pgRect.left + cr.width / 2;
        const cy = cr.top  - pgRect.top  + cr.height * 0.55;

        const dx = bx - cx;
        const dy = by - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const minD = br + cr.width * 0.35; // Precision targeting ink width

        if (dist < minD) {
          ch.dataset.freed = '1';
          ch.style.visibility = 'hidden';

          // Create a bouncing body for this char
          const el = document.createElement('span');
          el.className = 'bouncing-char';
          el.textContent = ch.textContent;
          el.style.position = 'absolute';
          el.style.left = `${cx - cr.width / 2}px`;
          el.style.top  = `${cy - cr.height * 0.55}px`;
          el.style.fontSize = twFontSize;
          el.style.zIndex = '90';
          playground.appendChild(el);

          // Launch away from ball
          const nx = dist > 0.1 ? dx / dist : 0;
          const ny = dist > 0.1 ? dy / dist : -1;
          const speed = Math.sqrt(bvx * bvx + bvy * bvy) * 0.5 + 200;

          bodies.push({
            el, x: cx, y: cy,
            vx: -nx * speed + (Math.random() - 0.5) * 150,
            vy: -ny * speed - 150 - Math.random() * 100,
            w: cr.width, h: cr.height,
            rot: 0,
            rotV: (Math.random() - 0.5) * 300,
          });
        }
      });
    }

    requestAnimationFrame(physicsTick);
  }

  // --- Dynamic Universal Accordion Logic ---
  const triggers = document.querySelectorAll('.accordion-trigger');
  
  // Start all contents openly
  const contents = document.querySelectorAll('.accordion-content');
  gsap.set(contents, { height: 'auto' });

  triggers.forEach((trigger) => {
    const parent = trigger.parentElement;
    const content = parent ? parent.querySelector('.accordion-content') : null;
    const icon = trigger.querySelector('.accordion-icon');
    
    // Store original colors to revert when opening
    const originalBg = (trigger as HTMLElement).style.backgroundColor;
    const originalColor = (trigger as HTMLElement).style.color;
    
    // All sections start open
    let isExpanded = true;

    if (content && icon) {
      
      // Set initial icon rotation since it's already open
      gsap.set(icon, { rotation: 45 });

      trigger.addEventListener('click', () => {
        if (!isExpanded) {
          
          // Animate Accordion Open
          gsap.to(content, { height: 'auto', duration: 0.6, ease: "power3.out" });

          // Animate any skill cards if this is the skills grid
          const skills = content.querySelectorAll('.skill-card-flow');
          if (skills.length > 0) {
            gsap.fromTo(skills, 
              { y: -50, opacity: 0, scale: 0.8, rotation: () => gsap.utils.random(-15, 15) },
              { y: 0, opacity: 1, scale: 1, rotation: 0, duration: 0.8, ease: "back.out(1.5)", stagger: 0.04 }
            );
          }

          // Trigger styling returns to default colorful
          gsap.to(trigger, {
            backgroundColor: originalBg,
            color: originalColor,
            duration: 0.4
          });
          
          // Icon rotates to 'x' indicating close
          gsap.to(icon, { rotation: 45, duration: 0.4, ease: "back.out(1.5)" });
          
          isExpanded = true;
        } else {
          
          // Animate Accordion Closed
          gsap.to(content, { height: 0, duration: 0.5, ease: "power3.inOut" });
          
          // Trigger styling turns into "Inactive state" (Black)
          gsap.to(trigger, {
            backgroundColor: 'var(--bauhaus-black)',
            color: 'var(--bauhaus-white)',
            duration: 0.4
          });
          
          // Icon returns to '+'
          gsap.to(icon, { rotation: 0, duration: 0.4, ease: "back.out(1.5)" });
          
          isExpanded = false;
        }
      });
    }
  });
</script>