---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

// Fetch all markdown files in the blog directory
const allPosts = Object.values(import.meta.glob<{ url: string, frontmatter: any }>('./*.md', { eager: true }));
const sortedPosts = allPosts;

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang);
---

<Layout title={`${t('blog.title')} | Alberto Maccanico`}>
  
  <div class="content-wrapper min-h-screen flex flex-col bg-white">
    
    <!-- BLOG HEADER -->
    <header class="p-6 sm:p-12 lg:p-16 flex flex-col justify-center bauhaus-border-b" style="background-color: var(--bauhaus-black); color: var(--bauhaus-white);">
      <a href={lang === 'en' ? '/' : `/${lang}`} class="inline-block px-4 py-2 border-[3px] border-[var(--bauhaus-white)] font-bold uppercase mb-8 sm:mb-12 w-fit hover:bg-[var(--bauhaus-white)] hover:text-black transition-colors">
        ← {t('blog.back')}
      </a>
      <h1 class="text-5xl sm:text-7xl lg:text-[8rem] font-black tracking-tighter leading-none mb-4">{t('blog.title')}</h1>
    </header>

    <!-- BLOG POSTS RULER LIST -->
    <div class="flex-1 flex flex-col">
      {sortedPosts.map((post, i) => {
        const bgs = ['var(--bauhaus-red)', 'var(--bauhaus-white)', 'var(--bauhaus-yellow)', 'var(--bauhaus-grey)'];
        const txs = ['var(--bauhaus-white)', 'var(--bauhaus-black)', 'var(--bauhaus-black)', 'var(--bauhaus-black)'];
        
        const bg = bgs[i % bgs.length];
        const tx = txs[i % txs.length];
        
        return (
          <a href={post.url} class="block p-6 sm:p-12 lg:p-16 bauhaus-border-b last:border-b-0 flex flex-col xl:flex-row justify-between xl:items-center gap-8 lg:gap-16 hover:opacity-90 transition-opacity" style={`background-color: ${bg}; color: ${tx};`}>
            <div class="xl:w-3/4">
              <h2 class="text-4xl sm:text-6xl lg:text-7xl font-black mb-4 sm:mb-6 tracking-tight leading-none">{post.frontmatter.title}</h2>
              <p class="text-xl sm:text-2xl lg:text-3xl font-medium max-w-4xl leading-tight">{post.frontmatter.description}</p>
            </div>
            
            <div class="xl:w-1/4 xl:text-right pt-4 xl:pt-0 flex flex-col xl:items-end gap-4">
               {post.frontmatter.publication && (
                 <span class="inline-block px-4 py-1 text-lg sm:text-xl font-bold uppercase border-2 mb-2" style={`border-color: ${tx};`}>
                   {post.frontmatter.publication}
                 </span>
               )}
               <span class="inline-block px-6 py-4 bg-black text-white text-2xl sm:text-3xl font-black uppercase transition-transform hover:-translate-y-1 w-fit" style={bg === 'var(--bauhaus-black)' ? 'background-color: white; color: black;' : ''}>
                 read article ↗
               </span>
            </div>
          </a>
        );
      })}
    </div>

  </div>
</Layout>
